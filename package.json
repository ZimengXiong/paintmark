{
  "name": "paintmark",
  "version": "0.1.0",
  "description": "A deterministic Markdown typesetter and native PDF renderer for TypeScript",
  "keywords": [
    "markdown",
    "pdf",
    "typescript",
    "typesetting",
    "gfm",
    "latex",
    "renderer"
  ],
  "homepage": "https://github.com/ZimengXiong/paintdown#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZimengXiong/paintdown.git"
  },
  "bugs": {
    "url": "https://github.com/ZimengXiong/paintdown/issues"
  },
  "author": "Zimeng Xiong",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "paintmark": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    },
    "./inter": {
      "types": "./dist/inter.d.ts",
      "import": "./dist/inter.js"
    }
  },
  "files": [
    "dist/**/*.d.ts",
    "dist/index.js",
    "dist/browser.js",
    "dist/inter.js",
    "dist/cli.js",
    "fonts/INTER-LICENSE.txt",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:site": "node scripts/build-site.mjs",
    "generate:art": "node scripts/generate-art.mjs",
    "verify:pdf": "npm run build && node scripts/verify.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "npm run typecheck && npm test && npm run build && npm run test:cli",
    "test:cli": "node dist/cli.js --version && node dist/cli.js README.md -o tmp/cli-smoke.pdf --blank-space-decoration none && node dist/cli.js README.md -o tmp/cli-smoke.html",
    "prepublishOnly": "npm run check"
  },
  "devDependencies": {
    "@mathjax/src": "^4.1.3",
    "@resvg/resvg-wasm": "^2.6.2",
    "@types/mdast": "^4.0.4",
    "@types/node": "^26.1.1",
    "@types/pako": "^2.0.4",
    "esbuild": "^0.28.1",
    "fast-png": "^8.0.0",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-gfm": "^3.1.0",
    "mdast-util-math": "^3.0.0",
    "micromark-extension-gfm": "^3.0.0",
    "micromark-extension-math": "^3.1.0",
    "pako": "^3.0.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
